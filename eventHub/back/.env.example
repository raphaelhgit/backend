# Configuration backend EventHub
# Copier ce fichier en .env et adapter les valeurs

# Port du serveur (défaut: 3000)
PORT=3000

# Secret JWT — OBLIGATOIRE en production (min 256 bits)
# Utiliser: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production

# Durée de validité du token JWT
JWT_EXPIRES_IN=24h

# URL du frontend (pour les headers CORS)
# En développement: http://localhost:5173 (port par défaut de Vite)
# En production: votre domaine frontend
FRONTEND_URL=http://localhost:5173

# Environnement (development / production)
NODE_ENV=development